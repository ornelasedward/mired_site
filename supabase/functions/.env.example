# Resend API key — Dashboard → API Keys
RESEND_API_KEY=re_...replace-me...

# Webhook signing secret — Resend → Webhooks → your endpoint → Signing secret
RESEND_WEBHOOK_SECRET=whsec_...replace-me...

# Where inbound contact notifications go (defaults to contact@mired.io)
NOTIFY_TO_EMAIL=contact@mired.io

# Forward a copy of each inbound email (contact@mired.io) to your personal inbox
INBOUND_FORWARD_EMAIL=contactmired@gmail.com

# Public site URL for invoice links in emails
PUBLIC_SITE_URL=https://mired.io

# Stripe — Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...replace-me...
STRIPE_WEBHOOK_SECRET=whsec_...replace-me...

# Cron auth for invoice-reminders and process-nurture-emails
CRON_SECRET=generate-a-long-random-string

# Calendly Embed API URL (confirmation/nurture emails)
CALENDLY_URL=https://calendly.com/YOUR_USERNAME/ai-readiness-call

# Calendly webhook signing key (from OAuth app → Webhook signing key)
CALENDLY_WEBHOOK_SIGNING_KEY=

# Optional OAuth credentials (not required for embed + webhooks)
# CALENDLY_CLIENT_ID=
# CALENDLY_CLIENT_SECRET=

# Site URL for share links in emails
SITE_URL=https://mired.io

# Optional CRM webhook — POST lead JSON on every form/assessment submission
# Works with HubSpot workflows, Attio, Zapier, Make, n8n, etc.
# CRM_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/...
# CRM_WEBHOOK_SECRET=optional-shared-secret

# Supabase injects these automatically when deployed; set locally for `supabase functions serve`
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
