# =============================================================================
# Frontend (Next.js) environment variables
# Copy to `.env.local` and fill in real values.
# =============================================================================

# Supabase — Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...replace-me...

# Calendly — scheduling page or specific event URL (powers the embed widget)
# Profile page works: https://calendly.com/YOUR_USERNAME
# Or a single event: https://calendly.com/YOUR_USERNAME/your-event-slug
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/YOUR_USERNAME

# Calendly OAuth/webhook secrets → Supabase Edge Function secrets only (see docs/calendly-setup.md)

# Legacy contact API (optional fallback if Supabase is not configured)
RESEND_EMAIL_API_KEY=re_...replace-me...
